{
  "name": "claude-micro-app",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/claude-micro-app",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "until mysqladmin ping -h db -u root -proot --silent 2>/dev/null; do sleep 2; done && npm install && bash .devcontainer/install.sh",
  "forwardPorts": [5173, 3000, 3306],
  "portsAttributes": {
    "5173": { "label": "Frontend (Vite)" },
    "3000": { "label": "Backend (Hono)" },
    "3306": { "label": "MySQL" }
  }
}
